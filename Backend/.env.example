# Copy this file to .env and change the values before running in production.

# PostgreSQL connection string. Create a local database first, e.g.:
#   createdb royal_care
# Then set user/password/host to match your local Postgres install.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/royal_care?schema=public

# Password required to log into /admin
ADMIN_PASSWORD=change-this-password

# Secret used to sign admin session tokens — use a long random string
JWT_SECRET=change-this-to-a-long-random-string

# Port the CMS server runs on
PORT=4000

# Origin of your React frontend (for CORS). Use the site's domain in production;
# * allows any origin (fine for local dev).
CORS_ORIGIN=*

# ---------------------------------------------------------------------------
# Email (Nodemailer) — sends an admin notification when the Contact form is
# submitted. Leave blank to disable email (messages still save to the DB).
# For Gmail, create an "App Password" and use it as SMTP_PASS.
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false                 # true for port 465, false for 587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# From address shown on the email (defaults to SMTP_USER if omitted)
MAIL_FROM="Royal Care Foundation <your-email@gmail.com>"
# Where contact-form notifications are delivered (defaults to SMTP_USER)
MAIL_TO=admin@royalcarefoundation.com
