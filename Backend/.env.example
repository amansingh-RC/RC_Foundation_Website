# Copy this file to .env and change the values before running in production.

# PostgreSQL connection string. Create a local database first, e.g.:
#   createdb royal_care
# Then set user/password/host to match your local Postgres install.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/royal_care?schema=public

# Password required to log into /admin
ADMIN_PASSWORD=change-this-password

# Secret used to sign admin session tokens — use a long random string
JWT_SECRET=change-this-to-a-long-random-string

# Port the CMS server runs on
PORT=4000

# Origin of your React frontend (for CORS). Use the site's domain in production;
# * allows any origin (fine for local dev).
CORS_ORIGIN=*
